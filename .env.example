# Supabase → Authentication → URL: Site URL = your real frontend (e.g. https://version2-smart-app-production.up.railway.app)
# Redirect URLs must include https://YOUR-FRONTEND.up.railway.app/** and .../auth
#
# Canonical SPA origin (no trailing slash). Set in production so confirmation emails use THIS host, not an old Railway URL.
# VITE_SITE_ORIGIN=https://version2-smart-app-production.up.railway.app
VITE_SUPABASE_URL=https://gdheohygyidipcsinudf.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdkaGVvaHlneWlkaXBjc2ludWRmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzAwNTc4MDAsImV4cCI6MjA4NTYzMzgwMH0.FAVkBk463cC_kxsXEQlLUUQ4iCwRshYP_5bYeI1Gny8

# Receipt scanning: optional DocTR API. Leave unset or empty on Railway — API uses Tesseract in Docker.
# For local DocTR: DOCTR_API_URL=http://127.0.0.1:8000
# DOCTR_API_URL=

# AI backend (categorization, anomaly detection, receipts). Required at Vite BUILD time for production.
# Local: http://127.0.0.1:5001  |  Production: https://YOUR-API-SERVICE.up.railway.app (no trailing slash)
VITE_AI_API_URL=http://127.0.0.1:5001

# Optional Railway frontend: inject deploy commit into the SPA (Settings footer). Use Variables → Reference to RAILWAY_GIT_COMMIT_SHA if the build does not see it automatically.
# VITE_GIT_SHA=

# Gemini (optional): Smart Money + Companion. Vite envDir is repo root — set in project .env, not frontend/.env
VITE_GEMINI_API_KEY=

# Email notifications (Nodemailer / SMTP)
NOTIFY_PORT=5174
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=
SMTP_FROM="UniGuard Wallet <your-email@gmail.com>"

# Outbound alert emails (notify server, Flask anomaly emails, frontend duplicate send). Set false to disable.
ENABLE_EMAIL_ALERTS=false
VITE_ENABLE_EMAIL_ALERTS=false