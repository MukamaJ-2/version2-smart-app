# AI backend (categorization, anomaly detection, receipts). Required at Vite BUILD time for production.
# Local: http://127.0.0.1:5001  |  Production: https://YOUR-API-SERVICE.up.railway.app (no trailing slash)
VITE_AI_API_URL=http://127.0.0.1:5001

